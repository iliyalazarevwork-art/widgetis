{
	"info": {
		"name": "Widgetis API v1",
		"description": "Widgetis backend API — Laravel 12 + JWT Auth\n\nВсе эндпоинты префиксированы /api/v1/\n\nПорядок работы:\n1. Отправьте OTP на email (Send OTP)\n2. Скопируйте код из логов Docker\n3. Проверьте OTP (Verify OTP) — токен автоматически сохранится\n4. Теперь все protected endpoints работают",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:8000/api/v1",
			"type": "string"
		},
		{
			"key": "token",
			"value": "",
			"type": "string"
		}
	],
	"item": [
		{
			"name": "Public",
			"item": [
				{
					"name": "Health Check",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/health",
							"host": ["{{base_url}}"],
							"path": ["health"]
						}
					}
				},
				{
					"name": "List Plans (UK)",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Accept-Language",
								"value": "uk"
							}
						],
						"url": {
							"raw": "{{base_url}}/plans",
							"host": ["{{base_url}}"],
							"path": ["plans"]
						}
					}
				},
				{
					"name": "List Plans (EN)",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Accept-Language",
								"value": "en"
							}
						],
						"url": {
							"raw": "{{base_url}}/plans",
							"host": ["{{base_url}}"],
							"path": ["plans"]
						}
					}
				}
			]
		},
		{
			"name": "Auth",
			"item": [
				{
					"name": "Send OTP",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"test@example.com\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/auth/otp",
							"host": ["{{base_url}}"],
							"path": ["auth", "otp"]
						}
					}
				},
				{
					"name": "Resend OTP",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"test@example.com\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/auth/otp/resend",
							"host": ["{{base_url}}"],
							"path": ["auth", "otp", "resend"]
						}
					}
				},
				{
					"name": "Verify OTP",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.token) {",
									"    pm.collectionVariables.set('token', jsonData.token);",
									"    console.log('Token saved automatically!');",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"test@example.com\",\n    \"code\": \"PASTE_CODE_HERE\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/auth/otp/verify",
							"host": ["{{base_url}}"],
							"path": ["auth", "otp", "verify"]
						}
					}
				},
				{
					"name": "Verify OTP (wrong code)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"test@example.com\",\n    \"code\": \"000000\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/auth/otp/verify",
							"host": ["{{base_url}}"],
							"path": ["auth", "otp", "verify"]
						}
					}
				},
				{
					"name": "Validation Error (empty body)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{}"
						},
						"url": {
							"raw": "{{base_url}}/auth/otp",
							"host": ["{{base_url}}"],
							"path": ["auth", "otp"]
						}
					}
				}
			]
		},
		{
			"name": "Auth (Protected)",
			"item": [
				{
					"name": "Get Current User",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"url": {
							"raw": "{{base_url}}/auth/user",
							"host": ["{{base_url}}"],
							"path": ["auth", "user"]
						}
					}
				},
				{
					"name": "Refresh Token",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.token) {",
									"    pm.collectionVariables.set('token', jsonData.token);",
									"    console.log('Token refreshed and saved!');",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"url": {
							"raw": "{{base_url}}/auth/refresh",
							"host": ["{{base_url}}"],
							"path": ["auth", "refresh"]
						}
					}
				},
				{
					"name": "Logout",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"url": {
							"raw": "{{base_url}}/auth/logout",
							"host": ["{{base_url}}"],
							"path": ["auth", "logout"]
						}
					}
				}
			]
		},
		{
			"name": "Error Cases",
			"item": [
				{
					"name": "401 — No Token",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/auth/user",
							"host": ["{{base_url}}"],
							"path": ["auth", "user"]
						}
					}
				},
				{
					"name": "401 — Invalid Token",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer invalid.token.here"
							}
						],
						"url": {
							"raw": "{{base_url}}/auth/user",
							"host": ["{{base_url}}"],
							"path": ["auth", "user"]
						}
					}
				},
				{
					"name": "404 — Not Found",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/nonexistent",
							"host": ["{{base_url}}"],
							"path": ["nonexistent"]
						}
					}
				}
			]
		}
	]
}
