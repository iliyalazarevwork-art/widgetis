widgetis.com, www.widgetis.com {

    encode gzip zstd

    request_body {
        max_size 20MB
    }

    # ── Backend: API ──────────────────────────────────────────
    handle /api/* {
        reverse_proxy backend:8000 {
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
        }
    }

    # ── Backend: Google OAuth & LiqPay ───────────────────────
    handle /auth/* {
        reverse_proxy backend:8000 {
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
        }
    }
    handle /liqpay/* {
        reverse_proxy backend:8000 {
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
        }
    }

    # ── Filament Admin Panel (at /manage) ────────────────────
    # React SPA occupies /admin; Filament is served at /manage
    handle /manage* {
        reverse_proxy backend:8000 {
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Host {host}
            header_up X-Forwarded-Proto {scheme}
        }
    }
    # Filament static assets (CSS/JS/Livewire)
    handle /livewire/* {
        reverse_proxy backend:8000 {
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Host {host}
            header_up X-Forwarded-Proto {scheme}
        }
    }
    handle /css/filament/* {
        reverse_proxy backend:8000 {
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Host {host}
            header_up X-Forwarded-Proto {scheme}
        }
    }
    handle /js/filament/* {
        reverse_proxy backend:8000 {
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Host {host}
            header_up X-Forwarded-Proto {scheme}
        }
    }

    # ── Backend: Widget delivery ──────────────────────────────
    handle /site/* {
        reverse_proxy backend:8000 {
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
        }
    }
    handle /content/* {
        reverse_proxy backend:8000 {
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
        }
    }
    handle /frontend/* {
        reverse_proxy backend:8000 {
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
        }
    }
    handle /bundles/* {
        reverse_proxy backend:8000 {
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
        }
    }
    handle /_widget/* {
        reverse_proxy backend:8000 {
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
        }
    }
    handle /seen_items/* {
        reverse_proxy backend:8000 {
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
        }
    }

    # ── Localized routes (/uk/_widget/, /en/_widget/, etc.) ───
    @localized path_regexp ^/[a-z]{2}(-[A-Z]{2})?/(_widget|seen_items)
    handle @localized {
        reverse_proxy backend:8000 {
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
        }
    }

    # ── Widget Builder ────────────────────────────────────────
    # Note: /modules, /build, /deploy are called WITHOUT trailing slash from the SPA,
    # so we use * (not /*) to match both the exact path and any subpath
    handle /build-demo* {
        reverse_proxy widget-builder:3200
    }
    handle /modules* {
        reverse_proxy widget-builder:3200
    }
    handle /build* {
        reverse_proxy widget-builder:3200 {
            transport http {
                response_header_timeout 120s
            }
        }
    }
    handle /deploy* {
        reverse_proxy widget-builder:3200 {
            transport http {
                response_header_timeout 120s
            }
        }
    }

    # ── Frontend SPA (catch-all) ──────────────────────────────
    # Handles: /, /admin/*, /cabinet/*, /login, /pricing, etc.
    handle {
        reverse_proxy frontend:80
    }
}
