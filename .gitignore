frontend/node_modules/
frontend/dist/
frontend/.vite/

# IDE / OS
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# Docker
docker-compose.override.yml

# Production secrets (never commit plain text)
.env.prod
backend/.env.prod.plain
certbot/

# SOPS encrypted secrets ARE committed
# backend/.env.enc  ← tracked in git (encrypted)
