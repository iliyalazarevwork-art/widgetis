APP_NAME=Widgetis
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:9001

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=widgetis
DB_USERNAME=widgetis
DB_PASSWORD=secret

CACHE_STORE=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis

REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log

JWT_SECRET=

WIDGET_BUILDER_URL=http://widget-builder:3200

R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=widgetis-cdn
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
R2_PUBLIC_URL=https://cdn.widgetis.com

FRONTEND_URL=http://localhost:5173

# Optional: used only if you explicitly run AdminSeeder
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Dev-only: accept master OTP code without email (never enable in production)
OTP_DEV_BYPASS=false
OTP_DEV_CODE=121212

LIQPAY_PUBLIC_KEY=
LIQPAY_PRIVATE_KEY=
LIQPAY_SANDBOX=true

# ── Monobank Acquiring ──────────────────────────────────────────────
# Token: X-Token from https://web.monobank.ua/ (sandbox in dev, prod
#        token in production — same API host, token scopes everything).
# Redirect: user lands here after the pay.mbnk.biz checkout page;
#           frontend's MyPlanPage polls /profile/subscription until
#           the webhook advances it to Active.
# Webhook: MUST be publicly reachable by Monobank's servers.
#         - dev: start `ngrok http 9001` and paste the https URL here
#         - prod: set this to https://api.<your-domain>/api/v1/webhooks/monobank
#         - localhost/127.0.0.1 will NOT work — Monobank can't reach it.
MONOBANK_TOKEN=
MONOBANK_REDIRECT_URL="${FRONTEND_URL}/cabinet/plan?payment=processing"
MONOBANK_WEBHOOK_URL="${APP_URL}/api/v1/webhooks/monobank"

# ── WayForPay Acquiring ─────────────────────────────────────────────
# Defaults point at WayForPay's public test merchant (docs: wiki.wayforpay.com)
# so dev just works. Override for prod via .env.production.
# merchant_domain_name MUST match the domain configured in the WFP cabinet or
# checkout returns error 1117 (signature mismatch) even with a correct secret.
# Webhook URL MUST be publicly reachable from WFP servers:
#  - dev: start `ngrok http 9001` and paste the https URL here
#  - prod: https://api.<your-domain>/api/v1/payments/wayforpay/callback
WAYFORPAY_MERCHANT_ACCOUNT=test_merch_n1
WAYFORPAY_SECRET_KEY=flk3409refn54t54t*FNJRET
WAYFORPAY_MERCHANT_DOMAIN_NAME=www.market.ua
WAYFORPAY_WEBHOOK_URL="${APP_URL}/api/v1/payments/wayforpay/callback"
WAYFORPAY_RETURN_URL="${FRONTEND_URL}/cabinet/plan?payment=processing"
WAYFORPAY_TRIAL_VERIFY_AMOUNT=1
WAYFORPAY_AUTO_REFUND_TRIAL=true

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
