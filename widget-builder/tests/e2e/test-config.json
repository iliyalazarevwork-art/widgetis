            "selector": ".j-product-block",
            "insert": "before"
          }
        ],
        "offsetDays": 3
      },
      "i18n": {
        "ua": {
          "prefix": "Очікувана доставка",
          "tomorrow": "завтра",
          "dayAfterTomorrow": "післязавтра",
