FROM node:22-alpine

WORKDIR /app

# No external dependencies — uses only Node stdlib.
COPY package.json ./
COPY server.mjs ./
# Pre-built obfuscated demo bundle (generated by `task build:demo` before
# image build). Optional: if missing, site-proxy falls back to serving
# pages without injected demo script.
COPY public ./public

ENV NODE_ENV=production
ENV PORT=3100
ENV DEMO_BUNDLE_PATH=/app/public/demo-bundle.js

EXPOSE 3100

CMD ["node", "server.mjs"]
