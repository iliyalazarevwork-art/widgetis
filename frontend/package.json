    "react-datepicker": "^9.1.0",
    "react-dom": "^19.2.4",
    "react-fast-marquee": "^1.6.5",
    "react-helmet-async": "^3.0.0",
    "react-international-phone": "^4.8.0",
    "react-router-dom": "^7.13.1",
    "simple-icons": "^16.14.0",
    "sonner": "^2.0.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
