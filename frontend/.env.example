# Frontend environment — Vite picks up VITE_* at build time.
# Copy to .env.local for local dev; real production values are injected
# by the build pipeline.

# ── API ─────────────────────────────────────────────────────────────
# Base URL of the Laravel backend API, including the /api/v1 suffix.
# - dev:  http://localhost:9002/api/v1 (matches backend APP_URL)
# - prod: https://api.<your-domain>/api/v1
#
# If this variable is omitted the client falls back to '/api/v1' on
# the same origin — handy when you front-proxy everything behind one
# domain.
VITE_API_BASE_URL=http://localhost:9002/api/v1

# ── Site-proxy preview iframe ────────────────────────────────────────
# Base URL of the site-proxy service used for the live demo iframe.
# - dev:  http://localhost:3100 (direct to the site-proxy container)
# - prod: https://preview.<your-domain>
#
# IMPORTANT: must be a different origin from the frontend so the sandboxed
# iframe cannot escape its sandbox via the same-origin loophole
# (allow-scripts + allow-same-origin on a same-origin iframe bypasses
# the sandbox and lets scripts navigate the parent window).
VITE_PREVIEW_BASE_URL=http://localhost:3100
